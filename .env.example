# Supabase — хранилище контента (возражения, этапы, скрипты, языки)
# И вход агентов по одноразовому коду на email (OTP).
# Берётся из Supabase → Project Settings → API.
# Если переменные не заданы — вход агентов недоступен, а приложение
# работает на встроенном статическом контенте (src/data/content.ts);
# админ-панель показывает предупреждение о ненастроенном Supabase.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
