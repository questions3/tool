# Единый пароль входа для всех агентов.
# Если не задан — используется пароль по умолчанию (000000).
# В Netlify задаётся в Site configuration → Environment variables.
VITE_APP_PASSWORD=

# Supabase — хранилище контента (возражения, этапы, скрипты, языки).
# Берётся из Supabase → Project Settings → API.
# Если переменные не заданы — приложение агента работает на встроенном
# статическом контенте (src/data/content.ts), а админ-панель показывает
# предупреждение о ненастроенном Supabase.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
